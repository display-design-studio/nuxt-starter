FROM oven/bun:1.3

WORKDIR /app

USER root

RUN apt-get update -y && apt-get install -y --no-install-recommends \
  bash \
  build-essential \
  ca-certificates \
  curl \
  git \
  gzip \
  fd-find \
  libpq-dev \
  libvips \
  libyaml-dev \
  make \
  pkg-config \
  python3 \
  python3-pip \
  ripgrep \
  tar \
  tzdata \
  unzip \
  wget \
  xz-utils \
  && rm -rf /var/lib/apt/lists/*
  
RUN ln -sf /usr/bin/fdfind /usr/local/bin/fd
ENV BUN_INSTALL_GLOBAL_DIR=/home/bun/.bun/install/global \
    BUN_INSTALL_BIN=/home/bun/.bun/bin \
    PATH="/home/bun/.bun/bin:$PATH"

RUN mkdir -p \
  /app \
  /home/bun/.bun \
  /home/bun/.config \
  /home/bun/.local/share \
  /home/bun/.cache \
  && chown -R bun:bun /app /home/bun
  
USER bun
# bun -g tools here (opencode, etc)

EXPOSE 3000
